{
  "schema_version": "1.0",
  "name": "5-node-breast-cancer",
  "description": "Compare ER+ vs ER- breast cancer tumors to identify DEGs, enriched pathways, and univariate associations using GSE25066 and GSE20194 (GPL96 platform)",
  "research_question": "Compare estrogen receptor positive (ER+) vs estrogen receptor negative (ER-) breast cancer tumors to identify differentially expressed genes. Grouping by er_status column (P = positive, N = negative).",
  "steps": [
    {
      "id": "fetch1",
      "node": "geo-microarray-processing@1.0.0",
      "config": {
        "subcommand": "fetch",
        "gse_id": "GSE25066",
        "rename": "er_status_ihc:group",
        "proxy": "http://127.0.0.1:2999",
        "outdir": "runs/5-node-breast-cancer/fetch1"
      }
    },
    {
      "id": "fetch2",
      "node": "geo-microarray-processing@1.0.0",
      "config": {
        "subcommand": "fetch",
        "gse_id": "GSE20194",
        "rename": "er_status:group",
        "proxy": "http://127.0.0.1:2999",
        "outdir": "runs/5-node-breast-cancer/fetch2"
      }
    },
    {
      "id": "merge",
      "node": "batch-correction@1.0.0",
      "config": {
        "subcommand": "intersect",
        "outdir": "runs/5-node-breast-cancer/merge"
      }
    },
    {
      "id": "deg",
      "node": "differential-analysis@1.0.0",
      "config": {
        "subcommand": "run",
        "method": "limma",
        "logfc_cutoff": 0.5,
        "outdir": "runs/5-node-breast-cancer/deg"
      }
    },
    {
      "id": "enrich",
      "node": "go-kegg-enrichment@1.0.0",
      "config": {
        "subcommand": "enrich",
        "tax-id": "9606",
        "outdir": "runs/5-node-breast-cancer/enrich"
      }
    },
    {
      "id": "univariate-filter",
      "node": "univariate-filter@1.0.0",
      "config": {
        "subcommand": "run",
        "outcome": "group",
        "outcome_type": "binary",
        "method": "logistic",
        "p_adjust": "BH",
        "sig_basis": "padj",
        "sig_threshold": 0.1,
        "outdir": "runs/5-node-breast-cancer/univariate-filter"
      }
    }
  ],
  "edges": [
    {"from": "fetch1", "to": "merge"},
    {"from": "fetch2", "to": "merge"},
    {"from": "merge", "to": "deg"},
    {"from": "deg", "to": "enrich"},
    {"from": "deg", "to": "univariate-filter"}
  ],
  "file_bindings": {
    "merge": {
      "--indir": {
        "sources": ["fetch1", "fetch2"],
        "resolve": "data_root",
        "note": "Node discovers expr_gene_*.csv recursively in each source's output directory"
      }
    },
    "deg": {
      "--mat": {
        "source_step": "merge",
        "semantic_type": "expression_matrix_gene",
        "prefer": "batch_corrected_expression.csv"
      },
      "--map": {
        "source_step": "merge",
        "semantic_type": "sample_metadata",
        "prefer": "shared_metadata.csv",
        "note": "Multi-column metadata; use --group-column group to select the unified group column"
      }
    },
    "enrich": {
      "--gene-list": {
        "source_step": "deg",
        "semantic_type": "differential_expression_results",
        "prefer": "Diffanalysis.csv",
        "note": "Extract significant gene symbols from Diffanalysis.csv for enrichment input"
      }
    },
    "univariate-filter": {
      "--in-mat": {
        "source_step": "merge",
        "semantic_type": "expression_matrix_gene",
        "prefer": "batch_corrected_expression.csv",
        "note": "Expression matrix; runtime should restrict to genes present in DEG results"
      },
      "--in-map": {
        "source_step": "merge",
        "semantic_type": "sample_metadata",
        "prefer": "shared_metadata.csv",
        "note": "Contains unified group column from fetch --rename output"
      }
    }
  },
  "data_type_notes": {
    "expression_data": "log2-transformed microarray (GPL96 Affymetrix HG-U133A)",
    "sample_count": "~800 (GSE25066: 508, GSE20194: 278)",
    "groups": {"P": "ER-positive", "N": "ER-negative"},
    "method_rationale": "Using limma because data is log2-transformed microarray; ComBat batch correction always-on; univariate logistic regression runs on DEG-restricted expression"
  },
  "created_at": "2026-07-02T00:00:00Z"
}
