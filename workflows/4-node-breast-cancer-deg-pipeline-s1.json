{
  "schema_version": "1.0",
  "name": "4-node-breast-cancer-deg-pipeline-s1",
  "description": "Compare ER-positive and ER-negative breast cancer tumors in GSE25066 and GSE20194, then enrich the resulting DEGs.",
  "research_question": "Compare estrogen receptor positive (P) vs estrogen receptor negative (N) breast cancer tumors to identify differentially expressed genes.",
  "steps": [
    {
      "id": "fetch1",
      "node": "geo-microarray-processing@1.0.0",
      "config": {
        "subcommand": "fetch",
        "gse_id": "GSE25066",
        "rename": "er_status_ihc:group",
        "proxy": "http://127.0.0.1:2999",
        "outdir": "runs/4-node-breast-cancer-deg-pipeline-s1/fetch1"
      }
    },
    {
      "id": "fetch2",
      "node": "geo-microarray-processing@1.0.0",
      "config": {
        "subcommand": "fetch",
        "gse_id": "GSE20194",
        "rename": "er_status:group",
        "proxy": "http://127.0.0.1:2999",
        "outdir": "runs/4-node-breast-cancer-deg-pipeline-s1/fetch2"
      }
    },
    {
      "id": "merge",
      "node": "batch-correction@1.0.0",
      "config": {
        "subcommand": "intersect",
        "batch_correction": true,
        "pattern": "expr_gene_*.csv",
        "outdir": "runs/4-node-breast-cancer-deg-pipeline-s1/merge"
      }
    },
    {
      "id": "deg",
      "node": "differential-analysis@1.0.0",
      "config": {
        "subcommand": "run",
        "group_column": "group",
        "method": "limma",
        "p_set": "padj",
        "logfc_cutoff": 0.5,
        "outdir": "runs/4-node-breast-cancer-deg-pipeline-s1/deg"
      }
    },
    {
      "id": "enrich",
      "node": "go-kegg-enrichment@1.0.0",
      "config": {
        "subcommand": "enrich",
        "tax_id": "9606",
        "outdir": "runs/4-node-breast-cancer-deg-pipeline-s1/enrich"
      }
    },
    {
      "id": "univariate-filter",
      "node": "univariate-filter@1.0.0",
      "config": {
        "subcommand": "run",
        "outcome": "group",
        "outcome_type": "binary",
        "method": "logistic",
        "p_adjust": "BH",
        "sig_basis": "padj",
        "sig_threshold": 0.1,
        "outdir": "runs/4-node-breast-cancer-deg-pipeline-s1/univariate-filter"
      }
    }
  ],
  "edges": [
    {"from": "fetch1", "to": "merge"},
    {"from": "fetch2", "to": "merge"},
    {"from": "merge", "to": "deg"},
    {"from": "deg", "to": "enrich"},
    {"from": "deg", "to": "univariate-filter"}
  ],
  "file_bindings": {
    "merge": {
      "--indir": {
        "sources": ["fetch1", "fetch2"],
        "resolve": "data_root",
        "pattern": "expr_gene_*.csv"
      }
    },
    "deg": {
      "--mat": {
        "source_step": "merge",
        "semantic_type": "expression_matrix_gene",
        "prefer": "batch_corrected_expression.csv",
        "fallback": "shared_expression.csv",
        "transform": "subset_samples_to_group_map",
        "output": "runs/4-node-breast-cancer-deg-pipeline-s1/deg/input_expression.csv"
      },
      "--map": {
        "source_steps": ["fetch1", "fetch2"],
        "semantic_type": "sample_metadata",
        "prefer": "metadata_*.csv",
        "transform": "extract_per_dataset_group_columns_and_filter",
        "per_dataset": {
          "GSE25066": {"id_column": "geo_accession", "group_column": "er_status_ihc:ch1"},
          "GSE20194": {"id_column": "geo_accession", "group_column": "er_status:ch1"}
        },
        "allowed_groups": ["P", "N"],
        "output": "runs/4-node-breast-cancer-deg-pipeline-s1/deg/sample_group.csv",
        "note": "Use metadata GEO accessions because fetch sample_group.csv contains clinical IDs that do not match matrix GSM headers, and merge shared_metadata.csv drops er_status during same-name unification."
      }
    },
    "enrich": {
      "--gene-list": {
        "source_step": "deg",
        "prefer": "DEGs.csv",
        "transform": "extract_first_column",
        "output": "runs/4-node-breast-cancer-deg-pipeline-s1/enrich/deg_gene_symbols.csv"
      }
    },
    "univariate-filter": {
      "--in-mat": {
        "source_step": "deg",
        "prefer": "DEGs.csv",
        "expression_source": "runs/4-node-breast-cancer-deg-pipeline-s1/deg/input_expression.csv",
        "transform": "subset_expression_features_by_deg_gene_id",
        "resolved": "runs/4-node-breast-cancer-deg-pipeline-s1/univariate-filter/input_degs_expression.csv"
      },
      "--in-map": {
        "source_steps": ["fetch1", "fetch2"],
        "transform": "extract_per_dataset_group_columns_and_filter",
        "allowed_groups": ["P", "N"],
        "resolved": "runs/4-node-breast-cancer-deg-pipeline-s1/deg/sample_group.csv"
      }
    }
  },
  "data_type_notes": {
    "expression_data": "log2-transformed GPL96 Affymetrix microarray expression",
    "groups": {"P": "ER-positive", "N": "ER-negative"},
    "method_rationale": "limma is appropriate for normalized log2 microarray expression."
  },
  "data_flow_warnings": [
    "The two datasets name ER status differently; fetch-time rename directives standardize their generated group files, while merge also unifies equivalent metadata columns.",
    "The enrichment input is generated inline from the first gene-symbol column of DEGs.csv.",
    "The univariate logistic input is generated by subsetting the group-aligned expression matrix to gene IDs retained in DEGs.csv."
  ],
  "created_at": "2026-06-30T00:00:00+08:00"
}
